RewriteEngine On

# Evitar que se vea la extensión .php en la URL (si alguien entra a /ejemplo.php lo mandamos a /ejemplo)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Si el archivo .php existe, lo servimos sin la extensión requerida
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Configurar index.php como página principal silenciosa si no cargamos nada
# (Apache lo suele hacer solo si DirectoryIndex está bien, pero esto asegura)
# DirectoryIndex index.php
